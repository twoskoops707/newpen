<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="13dp"
        android:paddingBottom="13dp">

        <TextView
            android:id="@+id/tvBadgeFlipper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="FLIP"
            android:textColor="@color/colorHardwareFlipper"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_badge_flip"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvBadgeAWOK"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="AWOK"
            android:textColor="@color/colorHardwareAWOK"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_badge_awok"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvBadgeBoth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="BOTH"
            android:textColor="@color/colorPrimary"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_badge_both"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="›"
            android:textColor="@color/colorTextMuted"
            android:textSize="18sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorStroke" />

</LinearLayout>
