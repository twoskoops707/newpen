<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
    android:layout_marginTop="5dp" android:layout_marginBottom="5dp"
    android:clickable="true" android:focusable="true"
    app:cardBackgroundColor="@color/colorCard"
    app:strokeColor="@color/colorStroke" app:strokeWidth="1dp"
    app:cardElevation="0dp" app:cardCornerRadius="14dp"
    app:rippleColor="@color/colorStrokeAlpha">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="9dp">
            <TextView android:id="@+id/tvBadgeFlipper" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="6dp" android:text="FLIPPER" android:textColor="@color/colorHardwareFlipper"
                android:textSize="8.5sp" android:fontFamily="monospace" android:textStyle="bold" android:letterSpacing="0.06"
                android:paddingStart="6dp" android:paddingEnd="6dp" android:paddingTop="2dp" android:paddingBottom="2dp"
                android:background="@drawable/bg_badge_flip" android:visibility="gone" />
            <TextView android:id="@+id/tvBadgeAWOK" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="6dp" android:text="AWOK" android:textColor="@color/colorHardwareAWOK"
                android:textSize="8.5sp" android:fontFamily="monospace" android:textStyle="bold" android:letterSpacing="0.06"
                android:paddingStart="6dp" android:paddingEnd="6dp" android:paddingTop="2dp" android:paddingBottom="2dp"
                android:background="@drawable/bg_badge_awok" android:visibility="gone" />
            <TextView android:id="@+id/tvBadgeBoth" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginEnd="6dp" android:text="BOTH" android:textColor="?attr/colorPrimary"
                android:textSize="8.5sp" android:fontFamily="monospace" android:textStyle="bold" android:letterSpacing="0.06"
                android:paddingStart="6dp" android:paddingEnd="6dp" android:paddingTop="2dp" android:paddingBottom="2dp"
                android:background="@drawable/bg_badge_both" android:visibility="gone" />
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
        </LinearLayout>

        <TextView android:id="@+id/tvTitle" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary" android:textSize="15sp" android:textStyle="bold"
            android:fontFamily="sans-serif" android:maxLines="2" android:ellipsize="end" android:lineSpacingMultiplier="1.2" />
        <TextView android:id="@+id/tvSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textColor="@color/colorTextSecondary" android:textSize="12sp"
            android:maxLines="2" android:ellipsize="end" android:lineSpacingMultiplier="1.35" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="11dp"
            android:text="open guide ›" android:textColor="?attr/colorPrimary" android:textSize="11sp"
            android:fontFamily="monospace" android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
