<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FlipperGuide" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/colorOnPrimaryContainer</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/colorOnSecondaryContainer</item>
        <item name="colorError">@color/colorError</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="android:statusBarColor">@color/colorStatusBar</item>
        <item name="android:navigationBarColor">@color/colorNavigationBar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.FlipperGuide.AlertDialog</item>
        <item name="toolbarStyle">@style/Widget.FlipperGuide.Toolbar</item>
        <item name="bottomNavigationStyle">@style/Widget.PenThis.BottomNav</item>
        <item name="materialCardViewStyle">@style/Widget.FlipperGuide.CardView</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.FlipperGuide.TitleLarge</item>
    </style>

    <style name="Widget.FlipperGuide.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/colorToolbar</item>
        <item name="titleTextColor">@color/colorTextPrimary</item>
        <item name="subtitleTextColor">@color/colorTextSecondary</item>
    </style>

    <style name="Widget.PenThis.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/colorNavBackground</item>
        <item name="itemIconTint">@color/bottomnav_item_color</item>
        <item name="itemTextColor">@color/bottomnav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.PenThis.BottomNav.Indicator</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.PenThis.NavLabel</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.PenThis.NavLabel</item>
    </style>

    <style name="Widget.PenThis.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/colorNavIndicator</item>
    </style>

    <style name="TextAppearance.PenThis.NavLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="Widget.FlipperGuide.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/colorCard</item>
        <item name="strokeColor">@color/colorStroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="rippleColor">@color/colorStrokeAlpha</item>
    </style>

    <style name="TextAppearance.FlipperGuide.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="ThemeOverlay.FlipperGuide.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/colorSurface</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
    </style>

    <style name="Widget.FlipperGuide.Button.Primary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="rippleColor">@color/colorStrokeAlpha</item>
    </style>

    <style name="Widget.FlipperGuide.Badge" parent="Widget.Material3.Button.TextButton">
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- ===== Accent theme variants (referenced by ThemeManager.styleRes) ===== -->
    <style name="Theme.PenThis.Terminal" parent="Theme.FlipperGuide">
        <item name="colorPrimary">#22C55E</item>
        <item name="colorPrimaryVariant">#22C55E</item>
        <item name="colorAccent">#22C55E</item>
        <item name="colorSecondary">#22C55E</item>
        <item name="android:statusBarColor">#060708</item>
        <item name="android:navigationBarColor">#070809</item>
    </style>

    <style name="Theme.PenThis.Phosphor" parent="Theme.FlipperGuide">
        <item name="colorPrimary">#F97316</item>
        <item name="colorPrimaryVariant">#F97316</item>
        <item name="colorAccent">#F97316</item>
        <item name="colorSecondary">#F97316</item>
        <item name="android:statusBarColor">#060708</item>
        <item name="android:navigationBarColor">#070809</item>
    </style>

    <style name="Theme.PenThis.Arctic" parent="Theme.FlipperGuide">
        <item name="colorPrimary">#06B6D4</item>
        <item name="colorPrimaryVariant">#06B6D4</item>
        <item name="colorAccent">#06B6D4</item>
        <item name="colorSecondary">#06B6D4</item>
        <item name="android:statusBarColor">#060708</item>
        <item name="android:navigationBarColor">#070809</item>
    </style>

    <style name="Theme.PenThis.Midnight" parent="Theme.FlipperGuide">
        <item name="colorPrimary">#A855F7</item>
        <item name="colorPrimaryVariant">#A855F7</item>
        <item name="colorAccent">#A855F7</item>
        <item name="colorSecondary">#A855F7</item>
        <item name="android:statusBarColor">#060708</item>
        <item name="android:navigationBarColor">#070809</item>
    </style>

    <style name="Theme.PenThis.Solar" parent="Theme.FlipperGuide">
        <item name="colorPrimary">#FBBF24</item>
        <item name="colorPrimaryVariant">#FBBF24</item>
        <item name="colorAccent">#FBBF24</item>
        <item name="colorSecondary">#FBBF24</item>
        <item name="android:statusBarColor">#060708</item>
        <item name="android:navigationBarColor">#070809</item>
    </style>

    <style name="Theme.PenThis.Ghost" parent="Theme.FlipperGuide">
        <item name="colorPrimary">#CBD5E1</item>
        <item name="colorPrimaryVariant">#CBD5E1</item>
        <item name="colorAccent">#CBD5E1</item>
        <item name="colorSecondary">#CBD5E1</item>
        <item name="android:statusBarColor">#060708</item>
        <item name="android:navigationBarColor">#070809</item>
    </style>

</resources>
